API_PORT=4110
WEB_PORT=5280

# Auth0 secure login (required for UI login)
VITE_AUTH_PROVIDER=auth0
VITE_AUTH0_DOMAIN=your_tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
# Optional for custom APIs/scopes
# VITE_AUTH0_AUDIENCE=
# VITE_AUTH0_SCOPE=openid profile email
# VITE_AUTH0_REDIRECT_URI=http://localhost:4110/
# VITE_AUTH0_CONNECTION=
# VITE_AUTH0_ORGANIZATION=

# Required for `npm run auth0:bootstrap-local`
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_AUDIENCE=https://your_tenant.us.auth0.com/api/v2/
AUTH0_DATABASE_CONNECTION=Username-Password-Authentication
AUTH0_LOCAL_USER_PASSWORD=password
# Optional: tenant/app logo shown by Auth0 Universal Login
AUTH0_BRANDING_LOGO_URL=https://www.michaelcoen.com/images/CDPH-Logo.png
# Optional: Auth0 application display name shown in Universal Login
AUTH0_APP_DISPLAY_NAME=CDPH HBEDS
# Optional: set to a single space to suppress "Log in to ... continue to ..." helper line
AUTH0_LOGIN_PROMPT_DESCRIPTION=" "

# Set OPENAI_API_KEY to enable live OpenAI-backed AI Helper responses.
OPENAI_API_KEY=
# Keep false in normal environments unless you explicitly want rule-based fallback locally.
HBEDS_AI_FALLBACK_ENABLED=false
# Optional overrides:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_HBEDS=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# CDC NHSN Bed Capacity API (May 2025 instructions)
# Set these to enable real outbound submissions:
# - OAuth token endpoint: https://apigw.cdc.gov/auth/oauth/v2/token
# - Upload endpoint: https://apigw.cdc.gov/DDID/NCEZID/l3nhsnbedcapacityapi/v1/messagerouter/upload/bedcapacity/json
CDC_NHSN_ENABLED=true
CDC_NHSN_ENV=sandbox
CDC_NHSN_TOKEN_URL=https://apigw.cdc.gov/auth/oauth/v2/token
CDC_NHSN_UPLOAD_URL=https://apigw.cdc.gov/DDID/NCEZID/l3nhsnbedcapacityapi/v1/messagerouter/upload/bedcapacity/json
CDC_NHSN_SCOPE=email profileid
CDC_NHSN_CLIENT_ID=
CDC_NHSN_CLIENT_SECRET=
CDC_NHSN_USERNAME=
CDC_NHSN_PASSWORD=
CDC_NHSN_TIMEOUT_MS=30000
